{
  "manifest_version": 3,
  "name": "SA Interview Bot",
  "version": "1.0.0",
  "description": "引導 SA 產出業務流程文件與 Mermaid 圖",
  "permissions": ["tabs", "storage", "scripting", "activeTab", "clipboardWrite"],
  "host_permissions": ["https://gemini.google.com/*"],
  "action": {
    "default_title": "SA Interview Bot"
  },
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "background": {
    "service_worker": "src/service-worker/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["src/content-script/gemini.ts"],
      "run_at": "document_idle"
    }
  ]
}
